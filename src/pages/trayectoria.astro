---
import Base from '../layouts/Base.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
import trayectoria from '../data/trayectoria.json';

const education = [
  "Periodista — Universidad Gabriela Mistral (1993-1997)",
  "Diplomado Comunicación Estratégica 2.0 — Universidad del Desarrollo (2009)",
  "Diplomado del Vino Chileno — Pontificia Universidad Católica de Chile (2014)",
  "Curso de Vino Argentino — The Wine Institute Mendoza (2016)",
  "WSET Nivel 2 — Conservatorio del Vino (2018)",
  "WSET Nivel 3 — The Wine School (2022)",
  "Diplomado Estrategias de Marketing Digital — Universidad de los Andes (2026, en curso)"
];
---

<Base title="María Paz Jiménez — Trayectoria">
  <div class="trayectoria-page">

    <!-- Page Header -->
    <header class="page-header">
      <div class="container">
        <h1 class="page-title">Trayectoria</h1>
        <p class="page-subtitle">{trayectoria.subtitle}</p>
      </div>
    </header>

    <!-- Career Timeline Blocks -->
    <section class="timeline-section">
      <div class="container timeline-container">
        {trayectoria.career.map((block, i) => (
          <div class="career-block">
            <div class="block-image-container">
              <ImageCarousel images={block.images} alt={block.title} ratio={block.ratio || "2 / 3"} />
            </div>
            <div class="block-content">
              <span class="block-period">{block.period}</span>
              <h3 class="block-title">{block.title}</h3>
              <p class="block-desc">{block.desc}</p>
              {block.extended_text && (
                <div class="block-extended" id={`ext-${i}`}>
                  <div class="extended-body" id={`ext-body-${i}`} hidden>
                    <p class="extended-text">{block.extended_text}</p>
                  </div>
                  <button
                    class="read-more-btn"
                    data-target={`ext-body-${i}`}
                    aria-expanded="false"
                    aria-controls={`ext-body-${i}`}
                  >
                    Leer más
                  </button>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Education Section -->
    <section class="education-section">
      <div class="container education-container">
        <div class="section-label">
          <span class="label-text">Formación y certificaciones</span>
          <span class="label-line"></span>
        </div>
        <ul class="education-list">
          {education.map((item) => (
            <li class="education-item">
              <span class="education-bullet">•</span>
              <span class="education-text">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

  </div>
</Base>

<script>
  document.querySelectorAll<HTMLButtonElement>('.read-more-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.target!;
      const body = document.getElementById(targetId);
      if (!body) return;
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      if (isExpanded) {
        body.hidden = true;
        btn.setAttribute('aria-expanded', 'false');
        btn.textContent = 'Leer más';
      } else {
        body.hidden = false;
        btn.setAttribute('aria-expanded', 'true');
        btn.textContent = 'Leer menos';
      }
    });
  });
</script>

<style>
  /* --- PAGE HEADER --- */
  .page-header {
    padding: 64px 0 32px 0;
    text-align: center;
    background-color: var(--bg);
  }

  .page-title {
    font-size: var(--text-2xl);
    font-style: italic;
    color: var(--text);
    margin-bottom: 16px;
    font-weight: 400;
  }

  .page-subtitle {
    font-size: var(--text-base);
    color: var(--muted);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* --- TIMELINE BLOCKS --- */
  .timeline-section {
    padding: var(--section-padding-vertical-mobile) 0;
    background-color: var(--bg);
    border-top: 1px solid var(--border);
  }

  .timeline-container {
    max-width: 900px;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .career-block {
    display: flex;
    flex-direction: column;
    gap: 24px;
    border-top: 1px solid var(--border);
    padding-top: 32px;
  }

  .career-block:first-child {
    border-top: none;
    padding-top: 0;
  }

  .block-image-container {
    width: 100%;
    overflow: hidden;
  }

  .block-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .block-period {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 13px;
    color: var(--accent);
    margin-bottom: 8px;
    letter-spacing: 0.02em;
  }

  .block-title {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--text);
    margin-bottom: 12px;
    font-weight: 400;
  }

  .block-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 12px;
  }

  /* Extended text / Read more */
  .block-extended {
    margin-top: 4px;
  }

  .extended-body {
    margin-bottom: 12px;
  }

  .extended-text {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
    border-left: 2px solid var(--border);
    padding-left: 16px;
    margin-top: 8px;
  }

  .read-more-btn {
    background: none;
    border: none;
    padding: 0;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--accent);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s ease;
  }

  .read-more-btn:hover {
    opacity: 0.7;
  }

  /* --- EDUCATION --- */
  .education-section {
    padding: var(--section-padding-vertical-mobile) 0;
    background-color: var(--surface);
    border-top: 1px solid var(--border);
  }

  .education-container {
    max-width: 900px;
  }

  .education-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .education-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 15px;
    color: var(--text);
    line-height: 1.5;
  }

  .education-bullet {
    color: var(--accent);
    font-size: var(--text-lg);
    line-height: 1;
    margin-top: -2px;
  }

  /* --- MEDIA QUERIES (768px+) --- */
  @media (min-width: 768px) {
    .page-header {
      padding: 80px 0 48px 0;
    }

    .page-title {
      font-size: 52px;
    }

    .timeline-section {
      padding: var(--section-padding-vertical-desktop) 0;
    }

    .timeline-container {
      gap: 72px;
    }

    .career-block {
      flex-direction: row;
      align-items: flex-start;
      gap: 56px;
    }

    .career-block:nth-child(even) {
      flex-direction: row-reverse;
    }

    .block-image-container {
      flex: 0 0 42%;
    }

    .block-content {
      flex: 1;
    }

    .block-title {
      font-size: 24px;
    }

    .education-section {
      padding: var(--section-padding-vertical-desktop) 0;
    }
  }
</style>
