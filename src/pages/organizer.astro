---
import Base from '../layouts/Base.astro';
import manifest from '../data/raw-images-manifest.json';
---

<Base title="Selección de Fotos — María Paz Jiménez">
  <div class="organizer-container">
    <header class="organizer-header">
      <h1 class="organizer-title">Selección y Categorización de Fotos</h1>
      <p class="organizer-subtitle">
        Navega por las fotos. Haz clic en los botones de sección debajo de cada imagen para asignarla. Los cambios se guardan automáticamente en tu navegador y puedes subirlos a la nube con el botón flotante inferior.
      </p>
    </header>

    <!-- Cloud Status Bar -->
    <div class="cloud-status-bar">
      <span class="status-indicator" id="cloud-status-text">Cargando selección guardada desde la nube...</span>
      <button id="sync-cloud-btn" class="btn-sync">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
        Sincronizar nube
      </button>
    </div>

    <!-- Filters Section -->
    <div class="filters-row">
      <button class="filter-btn active" data-filter="all">Todas las fotos</button>
      <button class="filter-btn" data-filter="trabaja_conmigo">Carpeta: Trabaja Conmigo</button>
      <button class="filter-btn" data-filter="trayectoria">Carpeta: Trayectoria</button>
    </div>

    <!-- Gallery Grid -->
    <main class="gallery-container">
      <div class="photos-grid" id="photos-grid"></div>
    </main>

    <!-- Sticky Bottom Bar -->
    <footer class="sticky-footer">
      <div class="footer-content">
        <div class="summary-counters">
          <span class="summary-title">Resumen:</span>
          <div class="counter-item">
            <span class="counter-dot com"></span>
            <span class="counter-label">Eventos: <strong id="count-com">0</strong></span>
          </div>
          <div class="counter-item">
            <span class="counter-dot cat"></span>
            <span class="counter-label">Catas: <strong id="count-cat">0</strong></span>
          </div>
          <div class="counter-item">
            <span class="counter-dot pod"></span>
            <span class="counter-label">Podcast: <strong id="count-pod">0</strong></span>
          </div>
          <div class="counter-item">
            <span class="counter-dot emp"></span>
            <span class="counter-label">Empresa: <strong id="count-emp">0</strong></span>
          </div>
          <div class="counter-item">
            <span class="counter-dot des"></span>
            <span class="counter-label">Descorchados: <strong id="count-des">0</strong></span>
          </div>
          <div class="counter-item">
            <span class="counter-dot val"></span>
            <span class="counter-label">Valdivieso: <strong id="count-val">0</strong></span>
          </div>
          <div class="counter-item">
            <span class="counter-dot gou"></span>
            <span class="counter-label">Gourmand: <strong id="count-gou">0</strong></span>
          </div>
        </div>

        <button id="save-cloud-btn" class="btn-save-cloud">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Guardar Cambios en la Nube
        </button>
      </div>
    </footer>
  </div>
</Base>

<!-- Pass manifest to client script -->
<script is:inline id="manifest-data" type="application/json" set:html={JSON.stringify(manifest)}></script>

<script>
  const API_URL = "https://keyvalue.immanuel.co/api/KeyVal";
  const APP_KEY = "ecmcx7yj";
  const ITEM_KEY = "selections";

  // Parse manifest
  const manifest = JSON.parse(document.getElementById('manifest-data').textContent);

  // Flatten manifest for gallery
  const allFiles = [];
  
  // Index lists mapping to retrieve indices easily
  const fileToIndexMap = {};
  
  const mapFolderFiles = (group, key) => {
    const list = manifest[group][key] || [];
    list.forEach((src, idx) => {
      const globalIndex = allFiles.length;
      fileToIndexMap[src] = idx;
      allFiles.push({ src, folder: group, subFolder: key, index: idx, globalIndex });
    });
  };

  mapFolderFiles('trabaja_conmigo', 'comunicacion_eventos');
  mapFolderFiles('trabaja_conmigo', 'catas_maridajes');
  mapFolderFiles('trabaja_conmigo', 'podcast');
  mapFolderFiles('trayectoria', 'mi_empresa');
  mapFolderFiles('trayectoria', 'descorchados');
  mapFolderFiles('trayectoria', 'vina_valdivieso');
  mapFolderFiles('trayectoria', 'revista_gourmand');

  // Selections state (contains indices of the manifest arrays instead of paths for compactness)
  let selections = {
    comunicacion_eventos: [],
    catas_maridajes: [],
    podcast: [],
    mi_empresa: [],
    descorchados: [],
    vina_valdivieso: [],
    revista_gourmand: []
  };

  // Section details
  const sections = [
    { key: 'comunicacion_eventos', label: 'Eventos', group: 'Inicio' },
    { key: 'catas_maridajes', label: 'Catas', group: 'Inicio' },
    { key: 'podcast', label: 'Podcast', group: 'Inicio' },
    { key: 'mi_empresa', label: 'Mi Empresa', group: 'Trayectoria' },
    { key: 'descorchados', label: 'Descorchados', group: 'Trayectoria' },
    { key: 'vina_valdivieso', label: 'Valdivieso', group: 'Trayectoria' },
    { key: 'revista_gourmand', label: 'Gourmand', group: 'Trayectoria' }
  ];

  // Base64URL encoding/decoding utilities
  function base64urlEncode(str) {
    return btoa(unescape(encodeURIComponent(str)))
      .replace(/\+/g, '-')
      .replace(/\//g, '_')
      .replace(/=/g, '');
  }

  function base64urlDecode(str) {
    if (!str) return '';
    let base64 = str.replace(/-/g, '+').replace(/_/g, '/');
    while (base64.length % 4) {
      base64 += '=';
    }
    return decodeURIComponent(escape(atob(base64)));
  }

  // DOM Elements
  const photosGrid = document.getElementById('photos-grid');
  const filterButtons = document.querySelectorAll('.filter-btn');
  const saveCloudBtn = document.getElementById('save-cloud-btn');
  const syncCloudBtn = document.getElementById('sync-cloud-btn');
  const cloudStatusText = document.getElementById('cloud-status-text');

  const counters = {
    comunicacion_eventos: document.getElementById('count-com'),
    catas_maridajes: document.getElementById('count-cat'),
    podcast: document.getElementById('count-pod'),
    mi_empresa: document.getElementById('count-emp'),
    descorchados: document.getElementById('count-des'),
    vina_valdivieso: document.getElementById('count-val'),
    revista_gourmand: document.getElementById('count-gou')
  };

  // Switch Filters
  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      filterButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      renderGallery(btn.dataset.filter);
    });
  });

  // Load selections from cloud
  async function loadFromCloud() {
    cloudStatusText.textContent = "Cargando selección guardada desde la nube...";
    cloudStatusText.className = "status-indicator loading";
    
    try {
      const res = await fetch(`${API_URL}/GetValue/${APP_KEY}/${ITEM_KEY}`);
      if (res.ok) {
        const encrypted = await res.json();
        if (encrypted && encrypted.trim() !== "") {
          const decrypted = base64urlDecode(encrypted);
          const parsed = JSON.parse(decrypted);
          
          // Apply selections
          Object.keys(selections).forEach(key => {
            selections[key] = Array.isArray(parsed[key]) ? parsed[key] : [];
          });
          
          localStorage.setItem('mpj-cloud-selections', JSON.stringify(selections));
          cloudStatusText.textContent = "Selección sincronizada con la nube.";
          cloudStatusText.className = "status-indicator success";
        } else {
          cloudStatusText.textContent = "Sin selección previa en la nube. ¡Empieza a elegir!";
          cloudStatusText.className = "status-indicator info";
        }
      } else {
        throw new Error();
      }
    } catch (e) {
      cloudStatusText.textContent = "Error al conectar con la nube. Cargando datos locales...";
      cloudStatusText.className = "status-indicator error";
      
      // Fallback to local storage
      const saved = localStorage.getItem('mpj-cloud-selections');
      if (saved) {
        selections = JSON.parse(saved);
      }
    }

    renderGallery();
    updateCounters();
  }

  // Save selections to cloud
  async function saveToCloud() {
    saveCloudBtn.disabled = true;
    saveCloudBtn.textContent = "Guardando...";
    cloudStatusText.textContent = "Guardando selección en el servidor...";
    cloudStatusText.className = "status-indicator loading";

    const dataString = JSON.stringify(selections);
    const encrypted = base64urlEncode(dataString);

    try {
      const res = await fetch(`${API_URL}/UpdateValue/${APP_KEY}/${ITEM_KEY}/${encrypted}`, {
        method: 'POST'
      });
      if (res.ok) {
        const val = await res.json();
        if (val === true || val === "True") {
          localStorage.setItem('mpj-cloud-selections', dataString);
          cloudStatusText.textContent = "¡Selección guardada en la nube con éxito!";
          cloudStatusText.className = "status-indicator success";
        } else {
          throw new Error();
        }
      } else {
        throw new Error();
      }
    } catch (e) {
      cloudStatusText.textContent = "Error de conexión: No se pudo guardar en la nube.";
      cloudStatusText.className = "status-indicator error";
      alert("Hubo un error al guardar en la nube. Inténtalo de nuevo.");
    }

    saveCloudBtn.disabled = false;
    saveCloudBtn.innerHTML = `
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
      Guardar Cambios en la Nube
    `;
  }

  // Render visual cards
  function renderGallery(filter = 'all') {
    photosGrid.innerHTML = '';

    const filteredFiles = allFiles.filter(item => {
      if (filter === 'all') return true;
      return item.folder === filter;
    });

    filteredFiles.forEach(item => {
      const card = document.createElement('div');
      card.className = 'photo-card';

      // Check if image index is selected in any section
      const selectedSections = sections.filter(sec => 
        selections[sec.key].includes(item.globalIndex)
      );

      if (selectedSections.length > 0) {
        card.classList.add('has-selections');
      }

      const fileName = item.src.split('/').pop();

      // Render Toggle Pills
      let initPills = '';
      let trayPills = '';

      sections.forEach(sec => {
        const isActive = selections[sec.key].includes(item.globalIndex);
        const pillHTML = `
          <button 
            class="pill-btn ${isActive ? 'active' : ''}" 
            data-global-index="${item.globalIndex}" 
            data-section="${sec.key}"
          >
            ${sec.label.split(' ')[0]}
          </button>
        `;
        if (sec.group === 'Inicio') {
          initPills += pillHTML;
        } else {
          trayPills += pillHTML;
        }
      });

      card.innerHTML = `
        <div class="card-image-wrap">
          <img src="${item.src}" alt="" loading="lazy" />
          <span class="zoom-indicator">Clic para ampliar</span>
        </div>
        <div class="card-content">
          <div class="card-filename" title="${fileName}">${fileName}</div>
          <div class="pills-group">
            <span class="pills-group-label">Página de Inicio</span>
            <div class="pills-row">${initPills}</div>
          </div>
          <div class="pills-group">
            <span class="pills-group-label">Trayectoria</span>
            <div class="pills-row">${trayPills}</div>
          </div>
        </div>
      `;

      // Handle Pill Toggle Click
      card.querySelectorAll('.pill-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const globalIdx = parseInt(btn.dataset.globalIndex, 10);
          const section = btn.dataset.section;
          const isActive = btn.classList.contains('active');

          if (isActive) {
            selections[section] = selections[section].filter(i => i !== globalIdx);
            btn.classList.remove('active');
          } else {
            if (!selections[section].includes(globalIdx)) {
              selections[section].push(globalIdx);
            }
            btn.classList.add('active');
          }

          // Toggle glow border on card
          const hasAny = sections.some(sec => selections[sec.key].includes(globalIdx));
          if (hasAny) {
            card.classList.add('has-selections');
          } else {
            card.classList.remove('has-selections');
          }

          updateCounters();
          
          // Auto-save local draft
          localStorage.setItem('mpj-cloud-selections', JSON.stringify(selections));
        });
      });

      // Zoom click handler
      card.querySelector('.card-image-wrap').addEventListener('click', () => {
        openModal(item.src);
      });

      photosGrid.appendChild(card);
    });
  }

  function updateCounters() {
    Object.keys(selections).forEach(key => {
      if (counters[key]) {
        counters[key].textContent = selections[key].length;
      }
    });
  }

  // Zoom Modal
  function openModal(src) {
    const modal = document.createElement('div');
    modal.className = 'zoom-modal';
    modal.innerHTML = `
      <div class="modal-backdrop"></div>
      <div class="modal-content-wrap">
        <img src="${src}" alt="" />
        <button class="close-modal-btn">Cerrar</button>
      </div>
    `;

    const closeModal = () => modal.remove();
    modal.querySelector('.modal-backdrop').addEventListener('click', closeModal);
    modal.querySelector('.close-modal-btn').addEventListener('click', closeModal);
    
    document.body.appendChild(modal);
  }

  // Bind save/sync buttons
  saveCloudBtn.addEventListener('click', saveToCloud);
  syncCloudBtn.addEventListener('click', loadFromCloud);

  // Initialize
  loadFromCloud();
</script>

<style>
  .organizer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 20px 140px 20px;
    font-family: var(--font-sans);
    color: var(--text);
  }

  .organizer-header {
    text-align: center;
    margin-bottom: 24px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 20px;
  }

  .organizer-title {
    font-size: 30px;
    color: #880000;
    font-family: var(--font-serif);
    font-style: italic;
    margin-bottom: 8px;
  }

  .organizer-subtitle {
    font-size: 13.5px;
    color: var(--muted);
    max-width: 720px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* Cloud Status Bar */
  .cloud-status-bar {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 10px 16px;
    border-radius: 6px;
    margin-bottom: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .status-indicator {
    font-size: 12px;
    font-weight: 500;
  }

  .status-indicator.loading { color: #880000; }
  .status-indicator.success { color: #2e7d32; font-weight: 600; }
  .status-indicator.error { color: #c62828; }
  .status-indicator.info { color: var(--text); }

  .btn-sync {
    background: #FFF;
    border: 1px solid var(--border);
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 500;
    cursor: pointer;
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    transition: all 0.2s ease;
  }

  .btn-sync:hover {
    border-color: #880000;
    color: #880000;
  }

  /* Filters */
  .filters-row {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 24px;
  }

  .filter-btn {
    background: #FFF;
    border: 1px solid var(--border);
    padding: 6px 14px;
    font-size: 12.5px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    border-radius: 4px;
    font-family: var(--font-sans);
  }

  .filter-btn:hover {
    border-color: #880000;
    color: #880000;
  }

  .filter-btn.active {
    background: var(--accent-lt);
    border-color: #880000;
    color: #880000;
  }

  /* Grid */
  .photos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
  }

  .photo-card {
    background: #FFF;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 8px rgba(0,0,0,0.02);
    transition: all 0.25s ease;
  }

  .photo-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0,0,0,0.05);
  }

  .photo-card.has-selections {
    border-color: #880000;
    box-shadow: 0 4px 12px rgba(136, 0, 0, 0.05);
  }

  .card-image-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    position: relative;
    overflow: hidden;
    background: var(--surface);
    cursor: pointer;
  }

  .card-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.2s ease;
  }

  .card-image-wrap:hover img {
    transform: scale(1.02);
  }

  .zoom-indicator {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(0,0,0,0.45);
    color: #FFF;
    font-size: 9px;
    text-align: center;
    padding: 3px 0;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .card-image-wrap:hover .zoom-indicator {
    opacity: 1;
  }

  .card-content {
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex-grow: 1;
  }

  .card-filename {
    font-size: 11px;
    font-weight: 500;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    border-bottom: 1px solid var(--border);
    padding-bottom: 6px;
  }

  .pills-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pills-group-label {
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
  }

  .pills-row {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .pill-btn {
    background: #FFF;
    border: 1px solid var(--border);
    padding: 3px 8px;
    font-size: 10px;
    font-weight: 500;
    cursor: pointer;
    border-radius: 20px;
    transition: all 0.15s ease;
    font-family: var(--font-sans);
  }

  .pill-btn:hover {
    border-color: #880000;
    color: #880000;
  }

  .pill-btn.active {
    background: #880000;
    border-color: #880000;
    color: #FFF;
  }

  /* Sticky Footer */
  .sticky-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.95);
    border-top: 1px solid var(--border);
    backdrop-filter: blur(10px);
    box-shadow: 0 -4px 16px rgba(0,0,0,0.04);
    padding: 14px 20px;
    z-index: 999;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  .summary-counters {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .summary-title {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--text);
  }

  .counter-item {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .counter-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .counter-dot.com { background-color: #ff5252; }
  .counter-dot.cat { background-color: #ffab40; }
  .counter-dot.pod { background-color: #40c4ff; }
  .counter-dot.emp { background-color: #e040fb; }
  .counter-dot.des { background-color: #69f0ae; }
  .counter-dot.val { background-color: #ffd740; }
  .counter-dot.gou { background-color: #b2ff59; }

  .counter-label {
    font-size: 11px;
    color: var(--muted);
  }

  .counter-label strong {
    color: var(--text);
    font-weight: 600;
  }

  .btn-save-cloud {
    background: #880000;
    color: #FFF;
    border: none;
    padding: 10px 20px;
    font-size: 11.5px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: background 0.2s ease;
    white-space: nowrap;
    font-family: var(--font-sans);
  }

  .btn-save-cloud:hover:not(:disabled) {
    background: #5f0000;
  }

  .btn-save-cloud:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Zoom Modal */
  .zoom-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .modal-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
  }

  .modal-content-wrap {
    position: relative;
    max-width: 90%;
    max-height: 90%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    z-index: 10001;
  }

  .modal-content-wrap img {
    max-width: 100%;
    max-height: 80vh;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    border-radius: 4px;
  }

  .close-modal-btn {
    background: #FFF;
    border: none;
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    border-radius: 4px;
    text-transform: uppercase;
  }
</style>
