---
import Base from '../layouts/Base.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
import content from '../data/home.json';
---

<Base title="María Paz Jiménez — Periodista y comunicadora de vinos">

  <!-- 1. HERO SECTION -->
  <section class="hero-section">
    <div class="container hero-container">
      <div class="hero-content">
        <div class="section-label centered hero-label">
          <span class="label-text">Periodista · Eventos · Podcast Vinos con Marypepa</span>
          <span class="label-line"></span>
        </div>
        <h1 class="hero-title">María Paz Jiménez</h1>
        <p class="hero-intro">{content.hero_intro}</p>
        <div class="hero-links">
          <a href="#contacto" class="btn-outline">Contactar</a>
          <a href="/trayectoria" class="btn-outline">Ver trayectoria</a>
        </div>
      </div>
      <div class="hero-mobile-block">
        <div class="section-label centered hero-label-mobile">
          <span class="label-text">Periodista · Eventos · Podcast Vinos con Marypepa</span>
        </div>
        <div class="hero-image-wrapper">
          <img src="/assets/MariaPaz-Portrait.png" alt="María Paz Jiménez" class="hero-image" />
        </div>
      </div>
    </div>
  </section>

  <!-- 2. QUIÉN SOY SECTION -->
  <section class="about-section" id="quien-soy">
    <div class="container about-container">
      <div class="section-label centered">
        <span class="label-text">Quién soy</span>
        <span class="label-line"></span>
      </div>
      <p class="about-text">{content.about_text}</p>
      <div class="about-links">
        <a href="https://www.youtube.com/@detripascorazonvinos" target="_blank" rel="noopener noreferrer" class="about-link">Vinos con Marypepa Podcast</a>
        <span class="about-link-sep">·</span>
        <a href="https://www.instagram.com/vinosconmarypepa/" target="_blank" rel="noopener noreferrer" class="about-link">Instagram</a>
        <span class="about-link-sep">·</span>
        <a href="https://www.linkedin.com/in/mpazjimenez/" target="_blank" rel="noopener noreferrer" class="about-link">LinkedIn</a>
      </div>
    </div>
  </section>

  <!-- 3. TRABAJA CONMIGO SECTION -->
  <section class="work-section" id="que-hago">
    <div class="container">
      <div class="section-label centered">
        <span class="label-text">Trabaja conmigo</span>
        <span class="label-line"></span>
      </div>
      <h2 class="section-title" style="text-align:center;">{content.work_title}</h2>

      <div class="work-grid">
        {content.work_cards.map((card) => (
          <div class="work-card">
            <div class="card-carousel-wrap">
              <ImageCarousel images={card.images} alt={card.title} />
            </div>
            <h3 class="card-title">{card.title}</h3>
            <p class="card-desc">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. CLIENTS SECTION -->
  <section class="clients-section">
    <div class="container clients-container">
      <div class="section-label centered">
        <span class="label-text">Clientes</span>
        <span class="label-line"></span>
      </div>
      <h2 class="section-title clients-title">Han confiado en mi trabajo</h2>
      <div class="clients-image-wrapper">
        <img src="/assets/clientes-logos-maria-paz.jpg" alt="Clientes de María Paz Jiménez" class="clients-image" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- 5. PODCAST SECTION -->
  <section class="podcast-section" id="podcast">
    <div class="container podcast-container">
      <div class="podcast-content">
        <div class="section-label">
          <span class="label-text">Proyecto destacado</span>
          <span class="label-line"></span>
        </div>
        <h2 class="podcast-title">Sigue Vinos con Marypepa, el Podcast del Vino Chileno</h2>
        <p class="podcast-desc">{content.podcast_desc}</p>
        <div class="podcast-chips">
          <a href="https://www.youtube.com/@detripascorazonvinos" target="_blank" rel="noopener noreferrer" class="btn-outline">
            <img src="/assets/icons/youtube-logo.svg" width="18" height="18" class="podcast-btn-icon" alt="" />
            YouTube
          </a>
          <a href="https://open.spotify.com/show/5JyFaOSOHuWG1PmKo462ZD?si=c1c5b6991ac34276" target="_blank" rel="noopener noreferrer" class="btn-outline">
            <img src="/assets/icons/spotify-logo.svg" width="18" height="18" class="podcast-btn-icon" alt="" />
            Spotify
          </a>
          <a href="https://podcasts.apple.com/us/podcast/vinos-con-marypepa/id1847634180" target="_blank" rel="noopener noreferrer" class="btn-outline">
            <img src="/assets/icons/apple-podcasts-logo.svg" width="18" height="18" class="podcast-btn-icon" alt="" />
            Apple Podcasts
          </a>
        </div>
      </div>
      <div class="podcast-image-container">
        <img src="/assets/VinosconMaripepa-Podcast.jpg" alt="Vinos con Maripepa Podcast" class="podcast-image" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- 6. CONTACT SECTION -->
  <section class="contact-section" id="contacto">
    <div class="container contact-container">
      <div class="section-label centered">
        <span class="label-text">Contacto</span>
        <span class="label-line"></span>
      </div>
      <h2 class="contact-title">Hablemos</h2>
      <p class="contact-desc">{content.contact_desc}</p>
      <div class="contact-buttons">
        <a href="https://wa.me/56998882760" target="_blank" rel="noopener noreferrer" class="btn-outline">
          <img src="/assets/icons/whatsapp-logo.svg" width="20" height="20" class="contact-icon" alt="" />
          WhatsApp
        </a>
        <a href="mailto:mariapaz@mariapazjimenez.cl" class="btn-outline">
          <img src="/assets/icons/envelope-simple.svg" width="20" height="20" class="contact-icon" alt="" />
          Email
        </a>
        <a href="https://www.instagram.com/mariapazjimenezvino/" target="_blank" rel="noopener noreferrer" class="btn-outline">
          <img src="/assets/icons/instagram-logo.svg" width="20" height="20" class="contact-icon" alt="" />
          Instagram
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* --- 1. HERO SECTION --- */
  .hero-section {
    padding: var(--section-padding-vertical-mobile) 0;
    background-color: var(--accent);
  }

  .hero-container {
    display: flex;
    flex-direction: column-reverse;
    gap: 40px;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-label {
    text-align: center;
    display: none;
  }

  .hero-label-mobile {
    display: flex;
    margin-bottom: 16px;
  }

  .hero-label .label-line,
  .hero-label-mobile .label-line {
    margin: 8px auto 0 auto;
  }

  .hero-mobile-block {
    width: 100%;
  }

  .hero-title {
    font-size: var(--text-2xl);
    color: var(--text);
    margin-bottom: 24px;
    font-weight: 600;
    font-style: italic;
  }

  .hero-intro {
    font-size: 18px;
    color: var(--muted);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 32px;
  }

  .hero-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
  }

  .hero-image-wrapper {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background-color: var(--surface);
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* --- HERO DARK OVERRIDES --- */
  .hero-section .hero-title { color: var(--white); }
  .hero-section .hero-intro { color: rgba(255,255,255,0.80); }
  .hero-section .label-text { color: rgba(255,255,255,0.65); }
  .hero-section .label-line { background-color: rgba(255,255,255,0.35); }
  .hero-section .btn-outline {
    border-color: rgba(255,255,255,0.70);
    color: var(--white);
  }
  .hero-section .btn-outline:hover {
    background-color: rgba(255,255,255,0.15);
    color: var(--white);
    border-color: var(--white);
  }
  .hero-section .hero-image-wrapper {
    box-shadow: 12px 12px 0 rgba(0,0,0,0.25), 0 4px 24px rgba(0,0,0,0.20);
  }

  /* --- 2. QUIÉN SOY SECTION --- */
  .about-section {
    background-color: var(--surface);
    padding: 64px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .about-container {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .about-text {
    font-family: var(--font-serif);
    font-size: 20px;
    font-style: italic;
    color: var(--text);
    line-height: 1.65;
    margin-bottom: 28px;
    max-width: 640px;
  }

  .about-links {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .about-link {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .about-link:hover {
    opacity: 0.7;
  }

  .about-link-sep {
    color: var(--border);
    font-size: 14px;
    user-select: none;
  }

  /* --- COMMON SECTION STYLES --- */
  .section-title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--text);
    text-align: left;
    margin-bottom: 48px;
    font-weight: 400;
  }

  /* --- 3. TRABAJA CONMIGO SECTION --- */
  .work-section {
    padding: var(--section-padding-vertical-mobile) 0;
    background-color: var(--bg);
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  .work-card {
    display: flex;
    flex-direction: column;
    border-top: 3px solid var(--border);
    padding-top: 0;
    transition: border-color 0.25s ease;
  }

  .work-card:hover {
    border-top-color: var(--accent);
  }

  .card-carousel-wrap {
    width: 100%;
    margin-bottom: 16px;
    overflow: hidden;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 20px;
    color: var(--text);
    margin-bottom: 12px;
    font-weight: 400;
    padding-top: 4px;
  }

  .card-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
  }

  /* --- 4. CLIENTS SECTION --- */
  .clients-section {
    padding: var(--section-padding-vertical-mobile) 0;
    background-color: var(--bg);
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .clients-title {
    text-align: center;
  }

  .clients-image-wrapper {
    max-width: 900px;
    margin: 0 auto;
    overflow: hidden;
  }

  .clients-image {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(100%);
    opacity: 0.7;
    transition: filter 0.3s ease, opacity 0.3s ease;
  }

  .clients-image:hover {
    filter: grayscale(0%);
    opacity: 1;
  }

  /* --- 5. PODCAST SECTION --- */
  .podcast-section {
    background-color: var(--surface);
    padding: var(--section-padding-vertical-mobile) 0;
    border-top: 1px solid var(--border);
  }

  .podcast-container {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .podcast-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .podcast-title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--text);
    margin-bottom: 16px;
    font-weight: 400;
    text-align: left;
  }

  .podcast-desc {
    font-size: 16px;
    color: var(--text);
    line-height: 1.7;
    max-width: 420px;
    margin-bottom: 32px;
  }

  .podcast-chips {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .podcast-btn-icon {
    width: 18px;
    height: 18px;
    object-fit: contain;
    filter: invert(9%) sepia(100%) saturate(7407%) hue-rotate(0deg) brightness(80%) contrast(110%);
    transition: filter 0.2s ease;
  }

  .btn-outline:hover .podcast-btn-icon {
    filter: brightness(0) invert(1);
  }

  .podcast-image-container {
    width: 100%;
    aspect-ratio: 4/3;
    background-color: var(--surface);
    overflow: hidden;
    position: relative;
    border: 1px solid var(--border);
    box-shadow: 8px 8px 0 var(--border);
  }

  .podcast-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: opacity 0.3s ease;
  }

  .podcast-image-container:hover .podcast-image {
    opacity: 0.92;
  }

  /* --- 6. CONTACT SECTION --- */
  .contact-section {
    background-color: var(--bg);
    padding: 80px 0;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .contact-container {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .contact-title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--text);
    margin-bottom: 16px;
    font-weight: 400;
  }

  .contact-desc {
    font-size: var(--text-base);
    color: var(--muted);
    max-width: 480px;
    margin: 0 auto 32px auto;
    line-height: 1.7;
  }

  .contact-buttons {
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 12px;
  }

  .contact-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
    filter: invert(9%) sepia(100%) saturate(7407%) hue-rotate(0deg) brightness(80%) contrast(110%);
    transition: filter 0.2s ease;
  }

  .btn-outline:hover .contact-icon {
    filter: brightness(0) invert(1);
  }

  /* --- MEDIA QUERIES (768px+) --- */
  @media (min-width: 768px) {
    .hero-section {
      padding: var(--section-padding-vertical-desktop) 0;
    }

    .hero-container {
      flex-direction: row;
      align-items: center;
      gap: 64px;
    }

    .hero-content {
      flex: 1.2;
    }

    .hero-label {
      display: flex;
      text-align: left;
    }

    .hero-label-mobile {
      display: none;
    }

    .hero-label .label-line {
      margin: 8px 0 0 0;
    }

    .hero-links {
      flex-direction: row;
      width: auto;
      gap: 16px;
      justify-content: flex-start;
    }

    .hero-mobile-block {
      flex: 0.8;
      max-width: 400px;
    }

    .hero-image-wrapper {
      aspect-ratio: 3/4;
      box-shadow: 12px 12px 0 rgba(0,0,0,0.25), 0 4px 24px rgba(0,0,0,0.20);
    }

    .hero-title {
      font-size: 64px;
    }

    .about-section {
      padding: 80px 0;
    }

    .about-text {
      font-size: 24px;
    }

    .section-title {
      font-size: 36px;
    }

    .work-section {
      padding: var(--section-padding-vertical-desktop) 0;
    }

    .work-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .clients-section {
      padding: var(--section-padding-vertical-desktop) 0;
    }

    .podcast-section {
      padding: var(--section-padding-vertical-desktop) 0;
    }

    .podcast-container {
      flex-direction: row;
      align-items: center;
      gap: 64px;
    }

    .podcast-content {
      flex: 1.2;
    }

    .podcast-chips {
      flex-direction: row;
    }

    .podcast-image-container {
      flex: 0.8;
      max-width: 440px;
    }

    .podcast-title {
      font-size: 38px;
    }

    .contact-title {
      font-size: 38px;
    }

    .contact-buttons {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 24px;
    }
  }

  /* --- MOBILE HEIGHT FIX --- */
  @media (max-width: 767px) {
    .hero-image-wrapper {
      max-height: 60vh;
    }

    .hero-image {
      object-fit: cover;
      object-position: center top;
    }
  }
</style>
