---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: any[]; // string[] o { src: string; position?: string }[]
  alt?: string;
  autoplay?: boolean;
  interval?: number;
}

const {
  images = [],
  alt = "",
  autoplay = true,
  interval = 4000,
} = Astro.props;

// Carga dinamica de las imagenes optimizadas de src/assets
const imagesGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/**/*.{jpeg,jpg,png,gif,webp,JPG,JPEG,PNG,WEBP}');

const resolvedImages = await Promise.all(
  images.map(async (item) => {
    const src = typeof item === 'string' ? item : item.src;
    const position = typeof item === 'string' ? 'center' : (item.position || 'center');

    let resolvedImg: string | ImageMetadata = src;
    if (typeof src === 'string' && src.startsWith('/src/assets/')) {
      const resolver = imagesGlob[src];
      if (resolver) {
        const mod = await resolver();
        resolvedImg = mod.default;
      }
    }
    return { img: resolvedImg, position };
  })
);

const uid = `c${Math.random().toString(36).slice(2, 8)}`;
const many = resolvedImages.length > 10; // con muchas fotos, contador en vez de puntos
---

{resolvedImages.length > 0 && (
  <div class="carousel" id={uid} data-autoplay={autoplay ? "true" : "false"} data-interval={interval}>
    <div class="carousel-track-wrap">
      <ul class="carousel-track">
        {resolvedImages.map((item, i) => (
          <li class="carousel-slide" aria-hidden={i !== 0 ? "true" : "false"}>
            {typeof item.img === 'string' ? (
              <img src={item.img} alt={`${alt} ${i + 1}`} style={{ objectPosition: item.position }} loading={i === 0 ? "eager" : "lazy"} decoding="async" draggable="false" />
            ) : (
              <Image src={item.img} alt={`${alt} ${i + 1}`} width={800} height={1200} quality={78} format="webp" style={{ objectPosition: item.position }} loading={i === 0 ? "eager" : "lazy"} decoding="async" draggable="false" />
            )}
          </li>
        ))}
      </ul>
    </div>

    {resolvedImages.length > 1 && (
      <>
        <button class="carousel-btn carousel-prev" aria-label="Anterior">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="carousel-btn carousel-next" aria-label="Siguiente">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>

        {many ? (
          <div class="carousel-counter"><span class="carousel-current">1</span> / {resolvedImages.length}</div>
        ) : (
          <div class="carousel-dots">
            {resolvedImages.map((_, i) => (
              <button class={`carousel-dot${i === 0 ? " active" : ""}`} aria-label={`Imagen ${i + 1}`} data-index={i}></button>
            ))}
          </div>
        )}
      </>
    )}
  </div>
)}

<style>
  .carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: var(--surface);
    aspect-ratio: 2 / 3;
  }

  .carousel-track-wrap {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    height: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* Clave del arreglo: cada slide ocupa EXACTAMENTE el ancho del contenedor,
     ni mas ni menos, sin importar el tamano natural de la foto. */
  .carousel-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    margin: 0;
  }

  .carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    user-select: none;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.85);
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text);
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 10;
    padding: 0;
  }

  .carousel:hover .carousel-btn,
  .carousel:focus-within .carousel-btn { opacity: 1; }

  /* En tactil no hay hover: dejar las flechas visibles y tenues */
  @media (hover: none) {
    .carousel-btn { opacity: 0.9; }
  }

  .carousel-prev { left: 10px; }
  .carousel-next { right: 10px; }
  .carousel-btn:hover { background: rgba(255, 255, 255, 1); }

  .carousel-dots {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 10;
  }

  .carousel-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.55);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .carousel-dot.active {
    background: rgba(255, 255, 255, 0.95);
    transform: scale(1.3);
  }

  .carousel-counter {
    position: absolute;
    bottom: 10px;
    right: 12px;
    z-index: 10;
    font-size: 0.7rem;
    font-weight: 500;
    color: #fff;
    background: rgba(0, 0, 0, 0.45);
    padding: 3px 8px;
    border-radius: 999px;
    letter-spacing: 0.02em;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.carousel').forEach((el) => {
    const wrap = el.querySelector<HTMLElement>('.carousel-track-wrap')!;
    const track = el.querySelector<HTMLElement>('.carousel-track')!;
    const slides = el.querySelectorAll<HTMLElement>('.carousel-slide');
    const dots = el.querySelectorAll<HTMLButtonElement>('.carousel-dot');
    const counter = el.querySelector<HTMLElement>('.carousel-current');
    const prevBtn = el.querySelector<HTMLButtonElement>('.carousel-prev');
    const nextBtn = el.querySelector<HTMLButtonElement>('.carousel-next');
    const total = slides.length;
    const autoplay = el.dataset.autoplay === 'true';
    const interval = parseInt(el.dataset.interval || '4000', 10);

    if (total <= 1) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    let visible = false;

    // Posicionar en pixeles reales del contenedor: nunca se desalinea,
    // sin importar el ancho de la tarjeta ni el tamano de la foto.
    function place(animate = true) {
      track.style.transition = animate ? '' : 'none';
      track.style.transform = `translateX(-${current * wrap.clientWidth}px)`;
      if (!animate) { void track.offsetWidth; track.style.transition = ''; }
    }

    function goTo(idx: number) {
      slides[current].setAttribute('aria-hidden', 'true');
      dots[current]?.classList.remove('active');
      current = (idx + total) % total;
      place();
      slides[current].setAttribute('aria-hidden', 'false');
      dots[current]?.classList.add('active');
      if (counter) counter.textContent = String(current + 1);
    }

    function startTimer() {
      if (!autoplay || !visible || timer) return;
      timer = setInterval(() => goTo(current + 1), interval);
    }
    function stopTimer() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    prevBtn?.addEventListener('click', () => { stopTimer(); goTo(current - 1); startTimer(); });
    nextBtn?.addEventListener('click', () => { stopTimer(); goTo(current + 1); startTimer(); });
    dots.forEach((dot, i) => dot.addEventListener('click', () => { stopTimer(); goTo(i); startTimer(); }));

    el.addEventListener('mouseenter', stopTimer);
    el.addEventListener('mouseleave', startTimer);

    // Reposicionar sin animar si cambia el ancho (rotar movil, redimensionar)
    let rz: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(rz);
      rz = setTimeout(() => place(false), 100);
    });

    // Solo autoreproducir cuando el carrusel esta a la vista: ahorra CPU y
    // evita que 6 carruseles corran a la vez fuera de pantalla.
    const io = new IntersectionObserver((entries) => {
      visible = entries[0].isIntersecting;
      if (visible) startTimer(); else stopTimer();
    }, { threshold: 0.25 });
    io.observe(el);

    // Deslizar con el dedo
    let x0 = 0;
    el.addEventListener('touchstart', (e) => { x0 = e.touches[0].clientX; }, { passive: true });
    el.addEventListener('touchend', (e) => {
      const diff = x0 - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) { stopTimer(); goTo(current + (diff > 0 ? 1 : -1)); startTimer(); }
    }, { passive: true });

    place(false);
  });
</script>
