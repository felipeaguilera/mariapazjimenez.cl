---
<footer class="footer">
  <div class="container footer-container">
    <div class="footer-top">
      <div class="footer-left">
        <a href="/" class="footer-logo-link">
          <span class="footer-logo-name">María Paz Jiménez</span>
          <span class="footer-logo-handle">@mariapazjimenezvino</span>
        </a>
      </div>
      <div class="footer-right">
        <nav class="footer-socials" aria-label="Redes sociales">
          <a href="https://www.instagram.com/mariapazjimenezvino/" target="_blank" rel="noopener noreferrer" class="social-link">Instagram</a>
          <span class="social-separator">·</span>
          <a href="https://www.youtube.com/@detripascorazonvinos" target="_blank" rel="noopener noreferrer" class="social-link">YouTube</a>
          <span class="social-separator">·</span>
          <a href="https://www.linkedin.com/in/mpazjimenez/" target="_blank" rel="noopener noreferrer" class="social-link">LinkedIn</a>
        </nav>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="copyright">
        © 2026 María Paz Jiménez · Inversiones Comunicaciones del Vino SpA
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--surface);
    color: var(--text);
    padding: 48px 0 24px 0;
    border-top: 1px solid var(--border);
  }

  .footer-container {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .footer-logo-link {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 3px;
    text-decoration: none;
  }

  .footer-logo-name {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 600;
    font-size: 26px;
    color: var(--text);
    line-height: 1;
  }

  .footer-logo-handle {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 9.5px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .footer-right {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-socials {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .social-link {
    color: var(--text);
    opacity: 0.6;
    transition: opacity 0.2s ease, color 0.2s ease;
  }

  .social-link:hover {
    opacity: 1;
    color: var(--accent);
  }

  .social-separator {
    color: var(--border);
    user-select: none;
  }

  .footer-bottom {
    border-top: 1px solid var(--border);
    padding-top: 24px;
    text-align: center;
  }

  .copyright {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    color: var(--text);
    opacity: 0.5;
  }

  /* Desktop layout (768px and up) */
  @media (min-width: 768px) {
    .footer {
      padding: 64px 0 32px 0;
    }

    .footer-top {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      text-align: left;
    }

    .footer-left {
      align-items: flex-start;
    }

    .footer-bottom {
      text-align: left;
    }
  }
</style>
